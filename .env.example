# ============================================================
# Dalio Autonomous Trading System — Environment Configuration
# Copy this file to .env and fill in your API keys.
# NEVER commit .env to version control.
# ============================================================

# ---- Market Data ----
# Alpha Vantage: https://www.alphavantage.co/support/#api-key (free tier available)
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_key_here
# iTick: https://itick.com.au (ASX real-time data)
ITICK_API_KEY=your_itick_key_here

# ---- Macro Economic Data ----
# EODHD: https://eodhd.com (GDP, CPI, interest rates)
EODHD_API_KEY=your_eodhd_key_here
TRADING_ECONOMICS_API_KEY=your_trading_economics_key_here

# ---- News ----
# Finnhub: https://finnhub.io (free tier: 60 calls/min)
FINNHUB_API_KEY=your_finnhub_key_here
# NewsAPI: https://newsapi.org (free tier: 100 calls/day)
NEWSAPI_API_KEY=your_newsapi_key_here

# ---- Notifications ----
# Discord: Server Settings > Integrations > Webhooks > Copy URL
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_ID/YOUR_TOKEN
# Telegram: Create bot via @BotFather, get chat_id via @userinfobot
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# ---- Database ----
DATABASE_URL=sqlite:///data/storage/trading.db

# ---- Risk Parameters (Dalio hard limits) ----
MAX_DAILY_LOSS_PCT=2.0
MAX_DRAWDOWN_PCT=10.0
MAX_PORTFOLIO_CORRELATION=0.3
MIN_DIVERSIFICATION_ASSETS=15

# ---- Trading Mode ----
# paper = simulated orders only (SAFE — default)
# live  = real order routing (requires broker integration)
TRADING_MODE=paper
